{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/api/admin/:path*", "destination": "/api/admin" },
    { "source": "/api/user/:path*",  "destination": "/api/user"  }
  ]
}
